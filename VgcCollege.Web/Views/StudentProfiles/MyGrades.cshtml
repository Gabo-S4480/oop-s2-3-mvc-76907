@model IEnumerable<VgcCollege.Domain.CourseEnrolment>

@{
    ViewData["Title"] = "My Academic Record";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary">My Grades</h1>
            <p class="text-muted">Below is the list of courses you are currently enrolled in and your results.</p>
        </div>
        <i class="bi bi-mortarboard-fill h1 text-secondary"></i>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Course Name</th>
                        <th>Status</th>
                        <th class="text-center">Final Grade</th>
                        <th class="text-center">Result</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <p class="mb-0">You are not enrolled in any courses yet.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle">
                                    <span class="fw-bold">@item.Course?.Name</span>
                                </td>
                                <td class="align-middle">
                                    <span class="badge rounded-pill @(item.Status == "Active" ? "bg-primary" : "bg-secondary")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    @if (item.Grade.HasValue)
                                    {
                                        <span class="h5 mb-0 @(item.Grade >= 40 ? "text-success" : "text-danger")">
                                            @item.Grade%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Pending</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    @if (item.Grade.HasValue)
                                    {
                                        if (item.Grade >= 40)
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Passed</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Failed</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">--</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Home
        </a>
    </div>
</div>