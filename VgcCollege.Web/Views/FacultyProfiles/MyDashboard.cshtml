@model IEnumerable<VgcCollege.Domain.Course>

@{
    ViewData["Title"] = "Faculty Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="display-4">Welcome to Your Dashboard</h1>
            <p class="lead">Below are the courses currently assigned to you.</p>
            <hr />
        </div>
    </div>

    <div class="row mt-3">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    You do not have any courses assigned at the moment.
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@item.Name</h5>
                            <h6 class="card-subtitle mb-2 text-muted">
                                <i class="bi bi-geo-alt"></i> Branch: @item.Branch?.Name
                            </h6>
                            <p class="card-text">
                                <strong>Schedule:</strong><br />
                                <span class="badge bg-secondary">@item.ScheduleDay</span>
                                <span class="badge bg-info text-dark">@item.ScheduleTime</span>
                            </p>
                            <p class="card-text text-small">
                                <small>Starts: @item.StartDate.ToShortDateString()</small><br />
                                <small>Ends: @item.EndDate.ToShortDateString()</small>
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-grid gap-2">
                                
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100">Course Details</a>

                                @* Button Gradebook *@
                                <a asp-action="Gradebook" asp-route-id="@item.Id" class="btn btn-success w-100">
                                    View Gradebook
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>