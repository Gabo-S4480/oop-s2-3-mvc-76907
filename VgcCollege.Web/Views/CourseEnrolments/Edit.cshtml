@model VgcCollege.Domain.CourseEnrolment

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

           
            <input type="hidden" asp-for="StudentProfileId" />
            <input type="hidden" asp-for="CourseId" />
            <input type="hidden" asp-for="EnrolDate" />
            <input type="hidden" asp-for="Status" />

            <div class="form-group mb-3">
                <label class="control-label">Student: @Model.Student?.Name</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Grade" class="control-label font-weight-bold">Final Grade (%)</label>
                <input asp-for="Grade" class="form-control" type="number" min="0" max="100" />
                <span asp-validation-for="Grade" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Grade" class="btn btn-primary" />
                <a asp-controller="FacultyProfiles" asp-action="Gradebook" asp-route-id="@Model.CourseId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>